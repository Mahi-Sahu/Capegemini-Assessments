<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
    <!--    to enable spring annotations-->
    <context:annotation-config/>

<!--    <bean id="employee" class="com.cg.bean.Employee" autowire="byType">-->
    <bean id="employee" class="com.cg.bean.Employee">
        <constructor-arg value="12345"/>
        <constructor-arg value="Rama"/>
        <constructor-arg value="12345.67"/>
        <constructor-arg value="PES-BU"/>
        <constructor-arg value="34"/>
        <constructor-arg ref="sbu"/>
    </bean>
<!--    <bean id="employee2" class="com.cg.bean.Employee" autowire="byType">-->
    <bean id="employee2" class="com.cg.bean.Employee">
        <constructor-arg value="12345"/>
        <constructor-arg value="Harriet"/>
        <constructor-arg value="40000.0"/>
        <constructor-arg value="PES-BU"/>
        <constructor-arg value="30"/>
        <constructor-arg ref="sbu"/>
    </bean>

    <bean id="sbu" class="com.cg.bean.SBU">
        <property name="sbuHead" value="Kiran Rao"/>
        <property name="sbuName" value="Product Engineering Services"/>
        <property name="empList">
            <list>
                <ref bean="employee"/>
                <ref bean="employee2"/>
            </list>
        </property>
    </bean>
</beans>